{
  "$id": "http://tsukuba-bunko.org/schemas/mockmoon-mapping.json",

  "type": "object",
  "additionalProperties": {
    "oneOf": [
      { "$ref": "#responseDef" },
      { "type": "array", "items": { "$ref": "#responseDef" }, "minItems": 1 }
    ]
  },

  "definitions": {
    "ResponseDef": {
      "type": "object",
      "$id": "responseDef",
      "properties": {
        "method": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
          ]
        },
        "condition": { "type": "string" },
        "status": { "type": "integer" },
        "headers": { "type": "object" },
        "cookies": { "type": "array", "items": { "$ref": "#cookieDef" } },
        "content-type": { "type": "string" },
        "content": { "type": "string" },
        "content-file": { "type": "string" },
        "filtering": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string" }
          ]
        }
      }
    },

    "CookieDef": {
      "type": "object",
      "$id": "cookieDef",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "string" },
        "options": {
          "type": "object",
          "properties": {
            "domain": { "type": "string" },
            "expires": { "type": "string" },
            "path": { "type": "string" },
            "httpOnly": { "type": "boolean" },
            "secure": { "type": "boolean" }
          }
        }
      },
      "required": ["name", "value"]
    }
  }
}